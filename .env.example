PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/fiberpass
FRONTEND_ORIGIN=http://localhost:3000
FIBER_NETWORK=testnet
FIBER_PROVIDER=rpc
# Local Fiber node default. In production point this at the authenticated HTTPS gateway from docs/fiber-node-deployment.md.
FIBER_RPC_URL=http://127.0.0.1:8227
FIBER_API_KEY=
# Local node peer id reported by node_info. Channel targets belong in FIBER_TARGET_PEER_IDS.
FIBER_PEER_ID=
FIBER_NODE_MIN_PEERS=1
FIBER_NODE_MIN_ACTIVE_CHANNELS=1
FIBER_NODE_MIN_OUTBOUND_LIQUIDITY_CKB=0.01
# Comma-separated external peer ids used when opening Fiber test channels.
FIBER_TARGET_PEER_IDS=
FIBER_TEST_CHANNEL_AMOUNT_CKB=0.01
FIBERPASS_DAILY_SESSION_SPEND_LIMIT_CKB=100000
FIBERPASS_TREASURY_ADDRESS=
FIBERPASS_VAULT_CODE_HASH=
FIBERPASS_VAULT_HASH_TYPE=data2
FIBERPASS_VAULT_CELL_DEP_TX_HASH=
FIBERPASS_VAULT_CELL_DEP_INDEX=
FIBERPASS_VAULT_CELL_DEP_TYPE=code
FIBERPASS_OPERATOR_LOCK_HASH=
FIBERPASS_OPERATOR_PRIVATE_KEY=
CKB_TESTNET_RPC_URL=https://testnet.ckb.dev
CKB_TESTNET_INDEXER_URL=https://testnet.ckb.dev
JOYID_SERVER_URL=https://api.testnet.joyid.dev/api/v1
REQUEST_BODY_LIMIT=128kb
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_APP_CHARGE_MAX=120
LOG_LEVEL=info

PAYMENT_WORKER_INTERVAL_MS=5000
PAYMENT_WORKER_BATCH_SIZE=10
WEBHOOK_WORKER_INTERVAL_MS=5000
WEBHOOK_WORKER_BATCH_SIZE=10
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
CRON_SECRET=
AUTOMATION_MAX_INVOICE_CKB=1000
AUTOMATION_MAX_BATCH_CKB=5000
AUTOMATION_DAILY_LIMIT_CKB=10000

# Email notifications
PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=xbeach329@gmail.com
SMTP_PASS=
EMAIL_FROM_ADDRESS=xbeach329@gmail.com
EMAIL_FROM_NAME=FiberPass
RECIPIENT_MAGIC_LINK_TTL_HOURS=72
