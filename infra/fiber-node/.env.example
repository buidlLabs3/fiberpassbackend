FIBER_IMAGE=nervos/fiber:0.9.0-rc7
FIBER_SECRET_KEY_PASSWORD=replace-with-a-long-node-password
FIBER_RPC_PROXY_TOKEN=replace-with-a-long-random-token
FIBER_RPC_DOMAIN=fiber-rpc.example.com
FIBER_PUBLIC_MULTIADDR=/ip4/YOUR_SERVER_PUBLIC_IP/tcp/8228
FIBER_RPC_LOCAL_PORT=8227
FIBER_P2P_PORT=8228
FIBER_ANNOUNCED_NODE_NAME=FiberPass Testnet Node
CKB_TESTNET_RPC_URL=https://testnet.ckb.dev/
RUST_LOG=info
PORT=8080
FIBER_NODE_CKB_PRIVATE_KEY=replace-with-node-funding-private-key
