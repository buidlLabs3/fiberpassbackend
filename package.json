{
  "name": "fiberpassbackend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "tsx src/tests/money.test.ts && tsx src/tests/fiberAddress.test.ts && tsx src/tests/vault.test.ts && tsx src/tests/ckbChain.test.ts && tsx src/tests/fiberProvider.rpc.test.ts && tsx src/tests/automationFlow.test.ts && tsx src/tests/appPermissions.test.ts",
    "vault:build": "node lockscripts/fiberpass-vault-lock/scripts/build-and-hash.mjs",
    "vault:deploy:testnet": "node lockscripts/fiberpass-vault-lock/scripts/deploy-testnet.mjs",
    "worker:payments": "tsx src/workers/paymentWorker.ts",
    "start:worker:payments": "node dist/workers/paymentWorker.js"
  },
  "dependencies": {
    "@ckb-lumos/lumos": "^0.23.0",
    "@joyid/ckb": "^1.1.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "mongoose": "^8.19.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
